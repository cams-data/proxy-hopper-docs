{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Proxy Hopper",
  "colors": {
    "primary": "#0D9488",
    "light": "#14B8A6",
    "dark": "#0F766E"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "height": 52
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/cams-data/proxy-hopper-v2"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Releases",
      "href": "https://github.com/cams-data/proxy-hopper-v2/releases"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/targets",
              "concepts/proxy-providers",
              "concepts/sending-requests"
            ]
          },
          {
            "group": "For Administrators",
            "pages": [
              {
                "group": "Configuration",
                "expanded": true,
                "pages": [
                  "admin/configuration/reference",
                  "admin/configuration/environment-variables"
                ]
              },
              {
                "group": "Deployment",
                "expanded": true,
                "pages": [
                  {
                    "group": "Docker",
                    "pages": [
                      "admin/deployment/docker/simple",
                      "admin/deployment/docker/advanced"
                    ]
                  },
                  {
                    "group": "Kubernetes",
                    "expanded": true,
                    "pages": [
                      "admin/deployment/kubernetes/helm",
                      "admin/deployment/kubernetes/high-availability",
                      "admin/deployment/kubernetes/monitoring"
                    ]
                  }
                ]
              },
              {
                "group": "Authentication",
                "expanded": true,
                "pages": [
                  "admin/authentication/overview",
                  "admin/authentication/api-keys",
                  "admin/authentication/user-based",
                  "admin/authentication/sso",
                  {
                    "group": "SSO Guides",
                    "pages": [
                      "admin/authentication/sso-guides/authentik",
                      "admin/authentication/sso-guides/azure"
                    ]
                  }
                ]
              },
              {
                "group": "Observability",
                "expanded": true,
                "pages": [
                  "admin/observability/metrics",
                  "admin/observability/logging"
                ]
              }
            ]
          },
          {
            "group": "For Developers",
            "pages": [
              "developers/getting-started",
              "developers/migrating",
              "developers/authenticating"
            ]
          },
          {
            "group": "For Contributors",
            "pages": [
              "contributors/architecture",
              "contributors/testing",
              "contributors/contributing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/cams-data/proxy-hopper-v2",
          "icon": "github"
        },
        {
          "anchor": "Releases",
          "href": "https://github.com/cams-data/proxy-hopper-v2/releases",
          "icon": "tag"
        }
      ]
    }
  },
  "styling": {
    "codeblocks": {
      "themes": {
        "light": "github-light",
        "dark": "catppuccin-mocha"
      }
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cams-data/proxy-hopper-v2"
    }
  }
}
